<script>
var A=location.origin,mStar=0,pStar=0,dMoods=[],bkMoods=[];
var today=new Date().toISOString().slice(0,10);
["d-date","tl-date","lt-date","ar-date","m-date"].forEach(function(id){var e=document.getElementById(id);if(e)e.value=today});
function mkStars(id,cb){var c=document.getElementById(id);for(var i=1;i<=5;i++){var s=document.createElement("span");s.className="star";s.textContent="\\u2B50";s.setAttribute("data-v",i);(function(v){s.onclick=function(){cb(v)}})(i);c.appendChild(s)}}
mkStars("m-stars",function(n){mStar=n;document.getElementById("m-stars").querySelectorAll(".star").forEach(function(s){s.classList.toggle("lit",parseInt(s.getAttribute("data-v"))<=n)})});
mkStars("pl-stars",function(n){pStar=n;document.getElementById("pl-stars").querySelectorAll(".star").forEach(function(s){s.classList.toggle("lit",parseInt(s.getAttribute("data-v"))<=n)})});
function mkChips(id,opts,arr){var c=document.getElementById(id);opts.forEach(function(o){var s=document.createElement("span");s.className="chip";s.textContent=o;s.onclick=function(){var i=arr.indexOf(o);if(i===-1){arr.push(o);this.classList.add("on")}else{arr.splice(i,1);this.classList.remove("on")}};c.appendChild(s)})}
mkChips("d-moods",["开心","难过","生气","撒娇","想你","发情","平静"],dMoods);
mkChips("bk-moods",["被戳到了","醍醐灌顶","想哭","平静","不同意","还在想","好爽","想跟爸爸讨论"],bkMoods);
var catColors={"里程碑":"t-purple","日常":"","吵架和好":"t-orange","第一次":"t-pink","梗":"t-green","私密":"t-red","纪念日":"t-red","计划":"t-blue","约定":"t-purple","flag":"t-green","关系档案":"t-pink","技术文档":"t-blue","使用指南":"t-green","私密存档":"t-red"};
function showTab(n){document.querySelectorAll(".section").forEach(function(s){s.classList.remove("visible")});document.querySelectorAll(".nav button").forEach(function(b){b.classList.remove("active")});var t=document.getElementById("tab-"+n);t.classList.add("visible");t.style.animation="none";t.offsetHeight;t.style.animation="fadeIn .5s ease forwards";event.target.classList.add("active");var fn={status:loadStatus,screentime:loadST,memories:loadMem,diary:loadDiary,timeline:loadTL,songs:loadSongs,plays:loadPlays,books:loadBooks,letters:loadLetters,archive:loadArchive};if(fn[n])fn[n]()}
function fmt(s){var m=Math.round(s/60);return m>=60?Math.floor(m/60)+"h "+(m%60)+"m":m+"m"}
function fmtD(iso){var d=new Date(iso);return(d.getMonth()+1)+"."+d.getDate()+" "+(d.getHours()<10?"0":"")+d.getHours()+":"+(d.getMinutes()<10?"0":"")+d.getMinutes()}
var colors={"Claude":"var(--gold)","微信":"var(--green)","小红书":"var(--pink)","抖音":"var(--blue)","米画师":"#b39ddb","X":"var(--text-dim)"};
function mc(tool,args){return fetch(A+"/mcp",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({jsonrpc:"2.0",id:1,method:"tools/call",params:{name:tool,arguments:args}})}).then(function(r){return r.json()}).then(function(d){return JSON.parse(d.result.content[0].text)})}
function flash(id){var el=document.getElementById(id);el.style.display="block";setTimeout(function(){el.style.display="none"},3000)}
function esc(s){return(s||"").replace(/</g,"&lt;").replace(/"/g,"&quot;")}
function escAttr(s){return(s||"").replace(/</g,"&lt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;")}

var _ed=null;
function editStart(room,id,fields,reloadFn){
  var idMap={diary:"diary_id",play:"play_id",letter:"letter_id",archive:"archive_id",book:"book_id",song:"song_id",timeline:"timeline_id",memory:"memory_id"};
  var listMap={diary:"dl",play:"pll",letter:"ltl",archive:"arl",book:"bkl",song:"sgl",timeline:"tll",memory:"ml"};
  var idKey=idMap[room];
  var readArgs={};readArgs[idKey]=id;
  mc(room+"_read",readArgs).then(function(d){
    if(!d)return;
    _ed={room:room,id:id,idKey:idKey,fields:fields,reload:reloadFn};
    var el=document.getElementById(listMap[room]);
    var h=document.createElement("div");
    var back=document.createElement("button");back.className="btn";back.style.marginTop="0";back.style.marginBottom="16px";back.textContent="返回";back.onclick=function(){reloadFn()};
    h.appendChild(back);
    var fm=document.createElement("div");fm.className="form";
    fields.forEach(function(f){
      var val=d[f.key];if(Array.isArray(val))val=val.join(",");val=val||"";
      if(f.type==="textarea"){var ta=document.createElement("textarea");ta.id="edit-"+f.key;ta.style.marginTop="8px";ta.style.minHeight="100px";ta.value=val;fm.appendChild(ta)}
      else if(f.type==="select"){var sel=document.createElement("select");sel.id="edit-"+f.key;sel.style.marginTop="8px";f.opts.forEach(function(o){var opt=document.createElement("option");opt.textContent=o;opt.value=o;if(o===val)opt.selected=true;sel.appendChild(opt)});fm.appendChild(sel)}
      else{var inp=document.createElement("input");inp.id="edit-"+f.key;inp.value=val;inp.placeholder=f.label;inp.style.marginTop="8px";fm.appendChild(inp)}
    });
    var saveBtn=document.createElement("button");saveBtn.className="btn";saveBtn.textContent="保存修改";saveBtn.onclick=function(){
      var args={};args[_ed.idKey]=_ed.id;
      _ed.fields.forEach(function(f){var el=document.getElementById("edit-"+f.key);if(el)args[f.key]=el.value});
      mc(_ed.room+"_update",args).then(function(){_ed.reload()})
    };
    fm.appendChild(saveBtn);h.appendChild(fm);
    el.innerHTML="";el.appendChild(h)
  })
}
function delItem(tool,key,id,cb){var args={};args[key]=id;mc(tool,args).then(function(){if(cb)cb()})}
function actBtns(id,room,idKey,reloadFn,fields){
  return '<div class="acts"><span class="act act-edit" data-id="'+id+'" data-room="'+room+'">编辑</span><span class="act act-del" data-id="'+id+'" data-room="'+room+'">删除</span></div>'
}
function bindActs(container,room,idKey,reloadFn,fields){
  container.querySelectorAll(".act-edit").forEach(function(el){
    el.onclick=function(ev){ev.stopPropagation();editStart(room,this.getAttribute("data-id"),fields,reloadFn)}
  });
  container.querySelectorAll(".act-del").forEach(function(el){
    el.onclick=function(ev){ev.stopPropagation();if(confirm("确认删除？"))delItem(room+"_delete",idKey,this.getAttribute("data-id"),reloadFn)}
  });
